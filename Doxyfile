# Doxyfile
#
# Doxygen configuration for generating browsable reference documentation for
# the Bootstrap shell source. The Makefile docs target downloads the Bash
# preprocessor filter before invoking this file.

PROJECT_NAME           = "Bootstrap"
PROJECT_BRIEF          = "Bash-based bootstrap engine reference documentation"

OUTPUT_DIRECTORY       = docs/reference
CREATE_SUBDIRS         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = .
GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

INPUT                  = src \
                         lib
RECURSIVE              = YES
FILE_PATTERNS          = *.bash \
                         *.sh

EXCLUDE                = dist \
                         docs \
                         tests \
                         vendor
EXCLUDE_PATTERNS       = */dist/* \
                         */docs/* \
                         */tests/* \
                         */vendor/*

EXTENSION_MAPPING      = bash=C \
                         sh=C
FILTER_PATTERNS        = *.bash=vendor/doxygen-bash.awk \
                         *.sh=vendor/doxygen-bash.awk

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES

OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_AS_ERROR          = NO
