# Makefile
#
# Canonical development and automation entry points for the bootstrap
# project.
#
# Phase 1 introduces a generated distribution artifact. Developers edit
# the modular source files listed in SOURCE_FILES. Users consume the
# generated dist/bootstrap.bash artifact produced by make all.

SHELL := /bin/bash
.SHELLFLAGS := -eu -o pipefail -c

DIST_DIR := dist
DIST_SCRIPT := $(DIST_DIR)/bootstrap.bash
SOURCE_FILES := lib/build-metadata.bash src/bootstrap.bash
TEST_SCRIPTS := tests/*.bats
TEST_RESULTS_DIR := test-results

VERSION ?= $(shell git describe --tags --always 2>/dev/null || printf '0.0.0-dev')
BUILD_COMMIT ?= $(shell git rev-parse --short=12 HEAD 2>/dev/null || printf 'unknown')
BUILD_DATE ?= $(shell git show -s --format=%cI HEAD 2>/dev/null || printf 'unknown')

.PHONY: all check clean format test test-report

all: $(DIST_SCRIPT)

$(DIST_SCRIPT): $(SOURCE_FILES)
	mkdir -p "$(DIST_DIR)"
	{ \
		printf '%s\n' '#!/usr/bin/env bash'; \
		printf '%s\n' '#'; \
		printf '%s\n' '# Generated by make all. Do not edit directly.'; \
		printf '%s\n' '# Source files: $(SOURCE_FILES)'; \
		printf '\n'; \
		printf 'BOOTSTRAP_VERSION=%q\n' "$(VERSION)"; \
		printf 'BOOTSTRAP_BUILD_DATE=%q\n' "$(BUILD_DATE)"; \
		printf 'BOOTSTRAP_BUILD_COMMIT=%q\n' "$(BUILD_COMMIT)"; \
		printf '\n'; \
		cat $(SOURCE_FILES); \
	} >"$@.tmp"
	chmod 0755 "$@.tmp"
	mv "$@.tmp" "$@"

##
# Run ShellCheck against hand-maintained Bash source files.
#
# The generated distribution artifact is intentionally excluded here. The
# checked source files are the source of truth, and make all assembles them into
# the release artifact.
#
check:
	shellcheck $(SOURCE_FILES)

##
# Format hand-maintained Bash source files using shfmt.
#
format:
	shfmt -w $(SOURCE_FILES)

##
# Run the behavior-oriented Bats test suite.
#
# The generated distribution artifact is a prerequisite because tests exercise
# the executable users will receive rather than the modular source files.
#
test: $(DIST_SCRIPT)
	bats $(TEST_SCRIPTS)

test-report: $(DIST_SCRIPT)
	mkdir -p "$(TEST_RESULTS_DIR)"
	bats --formatter junit $(TEST_SCRIPTS) >"$(TEST_RESULTS_DIR)/bats.xml"

clean:
	rm -rf "$(DIST_DIR)" "$(TEST_RESULTS_DIR)"
